## Window behaviour
set $float for_window [class=".*"] floating enable
# Uncomment to enable floating behaviour
#$float

for_window [app_id="dragon-drop"] floating enable, sticky enable
for_window [title="Picture-in-Picture"] floating enable, sticky enable, border pixel 2
for_window [title=".*Android Emulator.*"] floating enable, border none
for_window [title="win0"] floating enable
for_window [app_id="cpupower-gui"] floating enable, border pixel 2
for_window [app_id="thunderbird" instance="Calendar"] floating enable
for_window [app_id="thunderbird" instance="Msgcompose"] floating enable
for_window [class="ru-turikhay-tlauncher-bootstrap-Bootstrap"] floating enable
for_window [class="scrcpy"] focus, floating enable, move position -1 191, resize set 1922 890

xwayland enable
focus_follows_mouse no
mouse_warping none
# Use Mouse+$Mod to drag floating windows
floating_modifier $Mod

## Window style
default_floating_border pixel 2
default_border pixel 2
gaps inner 10
font pango: Nova Square 15

# Window border colours
set $tbg #10101088
set $bg #00000000
set $hi #77dd22
set $hi2 #54a015
set $con #ad30a8
set $text #f0eeea

# class                 border  bg    text    indic.  child_border
client.focused          $hi2    $tbg  $text   $con    $hi2
client.focused_inactive $bg     $tbg  $text   #32302d $bg
client.unfocused        $bg     $tbg  $text   #22201d $bg
client.background #00000000

## Workspaces
# simple formatting options
#set $w0 <span color=\"#888\"><b>1: </b></span>ï€•
set $w1 "ï€•"
set $w2 "ï…º"
set $w3 "<b>3</b>ï…º"
set $w4 "<b>4</b>ï…º"
set $w5 "ïƒ«"
set $w6 "ï€­"
set $w7 "ï¡¼"
set $w8 "ï‰©"
set $w9 "ï„›"

workspace $w1 output $display
workspace $w2 output $display
workspace $w3 output 2
workspace $w4 output 2
workspace $w5 output $display
workspace $w6 output $display
workspace $w7 output 2
workspace $w8 output 2
workspace $w9 output 2

workspace $w9 gaps inner 0
hide_edge_borders smart
smart_gaps on

assign [title=".*craft.*" class="Minecraft.*"] $w9
assign [class=".*.exe"] $w9
assign [class="[sS]team.*"] $w9
assign [app_id="firefox"] $w8
assign [app_id="vlc|mpv|Gimp|Inkscape"] $w7
assign [title=".*LibreOffice.*|Soffice"] $w6
assign [app_id="thunderbird|tutanota-desktop"] $w6
assign [class="NetBeans"] $w5

set $bar #222222ff

## Statusbar setup
bar {
	height 24
	status_command i3blocks
	# modes: dock, hide, invisible
	mode dock
	modifier $Mod+Ctrl
	separator_symbol " "
	position top

	colors {
		statusline $text
		#separator #aaaaaa
		background $bar
		# name             border   bg       fg
		focused_workspace  $bar     $bar     $hi2
		inactive_workspace $bar     $bar     $con
		urgent_workspace   $bar     $bar     #f03522
	}
}
