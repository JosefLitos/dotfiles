#!/usr/bin/env bash
# launch or focus app
# $1=app name; $2=displayed class; $3=optional, window name

TREE=$(swaymsg -t get_tree)

while IFS='"' read -a line; do
	case ${line[1]} in
		class)
			CLASS=${line[3]}
			;;
		app_id)
			ID=${line[3]}
			;;
		title)
			TITLE=${line[3]}
			break
			;;
	esac
done < <(echo "$TREE" | jq ".. | select(.type?) | select(.focused) | {app_id,window_properties}")

if [[ $3 ]]; then
	if [[ $TREE != *$3* || $TITLE == *$3* ]]; then
		swaymsg exec $1
		[[ $W ]] && swaymsg workspace $W
	else
		swaymsg [title="$3"] focus
	fi
elif [[ $TREE != *$2* || $CLASS$ID == *$2* ]]; then
	swaymsg exec $1
	[[ $W ]] && swaymsg workspace $W
else
	swaymsg [app_id="$2"] focus || swaymsg [class="$2"] focus
fi
